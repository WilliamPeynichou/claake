{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "main-no-system-access",
	"description": "Main webview may only open Stripe Checkout in the system browser.",
	"windows": ["main"],
	"permissions": [
		{
			"identifier": "opener:allow-open-url",
			"allow": [{ "url": "https://checkout.stripe.com/*" }]
		}
	]
}
