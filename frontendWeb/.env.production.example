# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === Backend API ===
# Must point to the deployed backend (no trailing slash, with /v1).
# Production builds fail if this is missing or points to localhost.
NEXT_PUBLIC_API_URL=https://api.claake.com/v1

# === Public web origin ===
NEXT_PUBLIC_WEB_URL=https://claake.com
