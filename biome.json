{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"javascript": {
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "warn",
				"noUnusedVariables": "warn"
			},
			"style": {
				"useImportType": "off"
			},
			"complexity": {
				"noStaticOnlyClass": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": [
				"**/*.spec.ts",
				"**/*.spec.tsx",
				"**/*.test.ts",
				"**/*.test.tsx",
				"**/test/**",
				"**/e2e/**"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		}
	],
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on"
				}
			}
		}
	},
	"files": {
		"includes": [
			"**/*.ts",
			"**/*.tsx",
			"**/*.js",
			"**/*.json",
			"!!**/.next",
			"!!**/node_modules",
			"!!**/*.config.mjs",
			"!!**/*.config.ts",
			"!!**/components/ui",
			"!!**/.claude",
			"!!supabase/.temp",
			"!!**/dist",
			"!!Pake",
			"!!skills",
			"!!ClaakePresentation"
		]
	}
}
