# Never commit real values. Copy this file to .env locally or inject values through the
# deployment platform's encrypted secret store. See docs/security/secrets-management.md.

# === Base ===
PORT=3001
NODE_ENV=development

# === Database (Prisma — Docker local) ===
DATABASE_URL=

# === Supabase (Cloud — Auth, Storage, Realtime) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Supabase Docker (BDD locale uniquement) ===
SUPABASE_DOCKER_URL=

# === OAuth GitHub (optional) ===
GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_CALLBACKURL=
GITHUB_CLIENT_SECRET=

# === Stripe (required in production when PaymentModule is enabled) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === Encryption (AES-256-GCM — 32 bytes hex) ===
ENCRYPTION_KEY=

# === Embeddings OpenAI (optional — keyword fallback when empty) ===
OPENAI_EMBEDDING_API_KEY=

# === Mistral OCR (optional — required for image-only PDF knowledge) ===
MISTRAL_API_KEY=

# === Frontend URLs (CORS) ===
WEB_URL=http://localhost:3000
