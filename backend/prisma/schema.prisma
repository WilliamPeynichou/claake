generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pg_trgm]
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  CREATOR
  ADMIN
  SUPER_ADMIN
}

enum TeamPlan {
  FREE
  TEAM
  ENTERPRISE
}

enum AgentStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum PricingModel {
  FREE
  ONE_TIME
  SUBSCRIPTION
  PAY_PER_USE
}

enum ExecutionMode {
  LOCAL
  CLOUD
  HYBRID
}

enum CloudStrategy {
  SELLER_ENDPOINT
  SELLER_API_KEY
  USER_API_KEY
}

enum EndpointFormat {
  OPENAI
  ANTHROPIC
  GOOGLE
  MISTRAL
  COHERE
  DEEPSEEK
  GROQ
  XAI
  PERPLEXITY
  META
  TOGETHER
  FIREWORKS
  HUGGINGFACE
  CLAAKE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum SecurityScanStatus {
  PENDING
  PASSED
  FAILED
  MANUAL_REVIEW
}

enum MessageContentType {
  TEXT
  IMAGE
  VIDEO
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum UploadedFileType {
  IMAGE
  DOCUMENT
}

enum McpReviewStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

// ─── Users & Teams ──────────────────────────────────────────────────────────

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  displayName      String?  @map("display_name")
  avatarUrl        String?  @map("avatar_url")
  bio              String?
  portfolioLinks   Json?    @map("portfolio_links")
  role             UserRole @default(USER)
  adminPermissions Json?    @map("admin_permissions")
  stripeAccountId  String?  @map("stripe_account_id")
  apiKeysEncrypted Json?    @map("api_keys_encrypted")
  preferences      Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  teamId String? @map("team_id")
  team   Team?   @relation("TeamMember", fields: [teamId], references: [id])

  ownedTeams    Team[]         @relation("TeamOwner")
  agents        Agent[]
  purchases     Purchase[]
  subscriptions Subscription[]
  reviews       Review[]
  collections   Collection[]
  pipelines     Pipeline[]
  favorites     Favorite[]
  usageCredits  UsageCredit[]
  chatSessions  ChatSession[]
  uploadedFiles UploadedFile[]

  @@index([email])
  @@map("users")
}

model Team {
  id               String   @id @default(uuid())
  name             String
  ownerId          String   @map("owner_id")
  plan             TeamPlan @default(FREE)
  stripeCustomerId String?  @map("stripe_customer_id")
  ssoConfig        Json?    @map("sso_config")
  createdAt        DateTime @default(now()) @map("created_at")

  owner   User   @relation("TeamOwner", fields: [ownerId], references: [id])
  members User[] @relation("TeamMember")

  @@index([ownerId])
  @@map("teams")
}

// ─── Agents ─────────────────────────────────────────────────────────────────

model Agent {
  id              String                       @id @default(uuid())
  name            String
  slug            String                       @unique
  description     String
  longDescription String?                      @map("long_description")
  category        String
  tags            String[]
  models          String[]                     @default(["claude-sonnet-4-20250514"])
  mode            ExecutionMode                @default(CLOUD)
  configUrl       String?                      @map("config_url")
  imageUrl        String?                      @map("image_url")
  screenshots     String[]
  pricingModel    PricingModel                 @default(FREE) @map("pricing_model")
  price           Decimal                      @default(0) @db.Decimal(10, 2)
  creditCost      Int                          @default(1) @map("credit_cost")
  status          AgentStatus                  @default(DRAFT)
  permissions     Json?
  downloadCount   Int                          @default(0) @map("download_count")
  rating          Decimal                      @default(0) @db.Decimal(3, 2)
  reviewCount     Int                          @default(0) @map("review_count")
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime                     @default(now()) @map("created_at")
  updatedAt       DateTime                     @updatedAt @map("updated_at")

  systemPrompt String? @map("system_prompt")

  welcomeMessage   String?  @map("welcome_message")
  suggestedPrompts String[] @default([]) @map("suggested_prompts")
  limitations      String[] @default([])
  modelSettings    Json?    @map("model_settings")
  capabilities     Json?
  variables        Json?
  fewShotExamples  Json?    @map("few_shot_examples")
  outputFormat     String?  @map("output_format")
  qualityChecklist String[] @default([]) @map("quality_checklist")
  tools            Json?

  cloudStrategy       CloudStrategy?  @map("cloud_strategy")
  endpointUrl         String?         @map("endpoint_url")
  endpointFormat      EndpointFormat? @map("endpoint_format")
  sellerApiKeyEncrypted String?       @map("seller_api_key_encrypted")
  sellerApiProvider   String?         @map("seller_api_provider")
  requiredUserProvider String?        @map("required_user_provider")
  dockerImage         String?         @map("docker_image")
  downloadUrl         String?         @map("download_url")

  deletedAt DateTime? @map("deleted_at")

  creatorId String @map("creator_id")
  creator   User   @relation(fields: [creatorId], references: [id])

  categoryRelation Category @relation("AgentCategory", fields: [category], references: [slug])

  versions         AgentVersion[]
  purchases        Purchase[]
  subscriptions    Subscription[]
  reviews          Review[]
  favorites        Favorite[]
  chatSessions     ChatSession[]
  collectionAgents CollectionAgent[]
  pipelineSteps    PipelineStep[]
  uploadedFiles    UploadedFile[]
  knowledge        AgentKnowledge[]
  knowledgeChunks AgentKnowledgeChunk[]
  mcpServers      McpServer[]

  @@index([slug])
  @@index([creatorId])
  @@index([category])
  @@index([status])
  @@index([tags], type: Gin)
  @@map("agents")
}

model AgentVersion {
  id                 String             @id @default(uuid())
  version            String
  configUrl          String             @map("config_url")
  changelog          String?
  securityScanStatus SecurityScanStatus @default(PENDING) @map("security_scan_status")
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @map("created_at")

  agentId String @map("agent_id")
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, version])
  @@index([agentId])
  @@map("agent_versions")
}

model McpServer {
  id                   String          @id @default(uuid())
  agentId              String          @map("agent_id")
  name                 String
  url                  String
  credentialsEncrypted String?         @map("credentials_encrypted")
  reviewStatus         McpReviewStatus @default(DRAFT) @map("review_status")
  reviewReason         String?         @map("review_reason")
  isActive             Boolean         @default(false) @map("is_active")
  submittedAt          DateTime?       @map("submitted_at")
  reviewedAt           DateTime?       @map("reviewed_at")
  reviewedBy           String?         @map("reviewed_by")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  agent Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tools McpTool[]

  @@index([agentId])
  @@index([reviewStatus, submittedAt])
  @@map("mcp_servers")
}

model McpTool {
  id          String   @id @default(uuid())
  serverId    String   @map("server_id")
  name        String
  description String?
  inputSchema Json     @map("input_schema")
  isSelected  Boolean  @default(false) @map("is_selected")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  server McpServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, name])
  @@index([serverId, isSelected])
  @@map("mcp_tools")
}

// ─── Commerce (Acheteur / Vendeur) ──────────────────────────────────────────

model Purchase {
  id              String   @id @default(uuid())
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("eur") @db.Char(3)
  stripePaymentId String?  @unique @map("stripe_payment_id")
  createdAt       DateTime @default(now()) @map("created_at")

  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id])
  agentId String @map("agent_id")
  agent   Agent  @relation(fields: [agentId], references: [id])

  @@unique([userId, agentId])
  @@index([userId])
  @@index([agentId])
  @@map("purchases")
}

model StripeWebhookEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique @map("event_id")
  type        String
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([type])
  @@map("stripe_webhook_events")
}

model Subscription {
  id               String             @id @default(uuid())
  stripeSubId      String?            @map("stripe_sub_id")
  status           SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd DateTime?          @map("current_period_end")
  createdAt        DateTime           @default(now()) @map("created_at")

  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id])
  agentId String @map("agent_id")
  agent   Agent  @relation(fields: [agentId], references: [id])

  @@index([userId])
  @@index([stripeSubId])
  @@map("subscriptions")
}

model UsageCredit {
  id        String   @id @default(uuid())
  balance   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  transactions CreditTransaction[]

  @@map("usage_credits")
}

model CreditTransaction {
  id        String   @id @default(uuid())
  amount    Int
  reason    String
  createdAt DateTime @default(now()) @map("created_at")

  usageCreditId String      @map("usage_credit_id")
  usageCredit   UsageCredit @relation(fields: [usageCreditId], references: [id])

  @@index([usageCreditId])
  @@map("credit_transactions")
}

// ─── Avis ───────────────────────────────────────────────────────────────────

model Review {
  id               String   @id @default(uuid())
  rating           Int      @db.SmallInt
  comment          String?
  verifiedPurchase    Boolean  @default(false) @map("verified_purchase")
  verifiedInteraction Boolean  @default(false) @map("verified_interaction")
  helpfulCount        Int      @default(0) @map("helpful_count")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id])
  agentId String @map("agent_id")
  agent   Agent  @relation(fields: [agentId], references: [id])

  @@unique([userId, agentId])
  @@index([agentId])
  @@map("reviews")
}

// ─── Activity Logs ──────────────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(uuid())
  actorId    String   @map("actor_id")
  actorEmail String   @map("actor_email")
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── Collections & Favoris ──────────────────────────────────────────────────

model Collection {
  id          String   @id @default(uuid())
  name        String
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  agents CollectionAgent[]

  @@index([userId])
  @@index([isPublic])
  @@map("collections")
}

model CollectionAgent {
  collectionId String @map("collection_id")
  agentId      String @map("agent_id")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  agent      Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@id([collectionId, agentId])
  @@map("collection_agents")
}

model Favorite {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id])
  agentId String @map("agent_id")
  agent   Agent  @relation(fields: [agentId], references: [id])

  @@unique([userId, agentId])
  @@index([userId])
  @@map("favorites")
}

// ─── Pipelines (Orchestration multi-agents) ─────────────────────────────────

model Pipeline {
  id          String   @id @default(uuid())
  name        String
  description String?
  config      Json?
  isPublic    Boolean  @default(false) @map("is_public")
  price       Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  steps PipelineStep[]

  @@index([userId])
  @@index([isPublic])
  @@map("pipelines")
}

model PipelineStep {
  id         String @id @default(uuid())
  step       Int
  config     Json?
  pipelineId String @map("pipeline_id")
  agentId    String @map("agent_id")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  agent    Agent    @relation(fields: [agentId], references: [id], onDelete: Restrict)

  @@unique([pipelineId, step])
  @@map("pipeline_steps")
}

// ─── Catalogue ──────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String
  icon        String
  agentCount  Int      @default(0) @map("agent_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  agents Agent[] @relation("AgentCategory")

  @@map("categories")
}

// ─── Chat ────────────────────────────────────────────────────────────────────

model ChatSession {
  id        String   @id @default(uuid())
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  agentId String @map("agent_id")
  agent   Agent  @relation(fields: [agentId], references: [id])

  messages      ChatMessage[]
  uploadedFiles UploadedFile[]

  @@index([userId, updatedAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id          String             @id @default(uuid())
  role        MessageRole
  contentType MessageContentType @default(TEXT) @map("content_type")
  content     String
  mediaUrl    String?            @map("media_url")
  metadata    Json?
  createdAt   DateTime           @default(now()) @map("created_at")

  sessionId String      @map("session_id")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  attachments UploadedFile[]

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

// ─── Fichiers uploadés ───────────────────────────────────────────────────────

model UploadedFile {
  id        String           @id @default(uuid())
  type      UploadedFileType @default(IMAGE)
  url       String
  fileName  String           @map("file_name")
  mimeType  String           @map("mime_type")
  size      Int
  createdAt DateTime         @default(now()) @map("created_at")

  // Uploader (user or creator/dev)
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  // Liens optionnels — un fichier peut être rattaché à un agent, une session ou un message
  agentId   String? @map("agent_id")
  agent     Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  sessionId String?      @map("session_id")
  session   ChatSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  messageId String?      @map("message_id")
  message   ChatMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([agentId])
  @@index([sessionId])
  @@index([messageId])
  @@map("uploaded_files")
}

model AgentKnowledge {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  chunks    AgentKnowledgeChunk[]

  @@index([agentId])
  @@map("agent_knowledge")
}

model AgentKnowledgeChunk {
  id          String   @id @default(uuid())
  agentId     String   @map("agent_id")
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  knowledgeId String   @map("knowledge_id")
  knowledge   AgentKnowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  chunkIndex  Int      @map("chunk_index")
  content     String
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([knowledgeId, chunkIndex])
  @@index([agentId])
  @@index([knowledgeId])
  @@map("agent_knowledge_chunks")
}
