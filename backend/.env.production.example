# Template only. Store production values in the deployment platform secret manager.
# Never create or commit a populated .env.production file.

# === Base ===
PORT=3001
NODE_ENV=production

# === Database (Prisma) ===
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&sslmode=require
DATABASE_URL=

# === Supabase (Auth, Storage, Realtime) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Encryption (AES-256-GCM — must be exactly 32 bytes, hex-encoded = 64 chars) ===
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# === Embeddings OpenAI (optional — keyword fallback when empty) ===
OPENAI_EMBEDDING_API_KEY=

# === Frontend URLs (CORS whitelist) ===
# Production must be https:// and must not contain a trailing slash.
WEB_URL=https://claake.com

# === OAuth GitHub (if enabled) ===
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_CALLBACKURL=https://claake.com/auth/callback/github

# === Stripe (required in production while PaymentModule is enabled) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
